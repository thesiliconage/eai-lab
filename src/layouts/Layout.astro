---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'EAI LAB — Embodied Intelligence Research Center.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="/fonts/inter-var.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site?.href || 'https://www.eailab.site').href} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site?.href || 'https://www.eailab.site').href} />
  <title>{title}</title>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-inner">
      <a href="/" class="header-logo">EAI<span>LAB</span></a>
      <div class="search-box">
        <span class="search-icon">🔍</span>
        <input type="text" placeholder="Search topics..." id="search-input" />
      </div>
      <nav class="header-links">
        <a href="/#topics">Topics</a>
        <a href="/#about">About</a>
        <a href="mailto:contact@mail.eailab.site">Contact</a>
      </nav>
      <button class="menu-btn" aria-label="Menu" id="menu-btn">☰</button>
    </div>
  </header>

  <!-- Mobile nav -->
  <div class="mobile-nav" id="mobile-nav">
    <div class="sidebar-section">
      <div class="sidebar-title">Navigation</div>
      <a href="/" class="sidebar-link">📖 Introduction</a>
      <a href="/#topics" class="sidebar-link">📚 Topic Index</a>
      <a href="/#about" class="sidebar-link">ℹ️ About</a>
      <a href="mailto:contact@mail.eailab.site" class="sidebar-link">✉️ Contact</a>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-title">Research Areas</div>
      <a href="/#manipulation" class="sidebar-link">🦾 Manipulation</a>
      <a href="/#navigation" class="sidebar-link">🗺️ Navigation</a>
      <a href="/#language" class="sidebar-link">💬 Language</a>
      <a href="/#sim2real" class="sidebar-link">🔄 Sim-to-Real</a>
      <a href="/#multiagent" class="sidebar-link">🤝 Multi-Agent</a>
      <a href="/#hri" class="sidebar-link">🧩 Human-Robot</a>
      <a href="/#railway" class="sidebar-link">🚆 Railway AI</a>
      <a href="/#field" class="sidebar-link">🏗️ Field Robotics</a>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-title">Impact</div>
      <a href="/#impact" class="sidebar-link">🏥 Healthcare</a>
      <a href="/#impact" class="sidebar-link">🏭 Industry</a>
      <a href="/#impact" class="sidebar-link">🌾 Agriculture</a>
    </div>
  </div>

  <div class="layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-section">
        <div class="sidebar-title">Getting Started</div>
        <a href="/" class="sidebar-link active">📖 Introduction</a>
        <a href="/#topics" class="sidebar-link">📚 Topic Index</a>
        <a href="/#about" class="sidebar-link">ℹ️ What is Embodied AI</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-title">Research Areas</div>
        <a href="/#manipulation" class="sidebar-link">🦾 Manipulation</a>
        <a href="/#navigation" class="sidebar-link">🗺️ Navigation</a>
        <a href="/#language" class="sidebar-link">💬 Language & Action</a>
        <a href="/#sim2real" class="sidebar-link">🔄 Sim-to-Real</a>
        <a href="/#multiagent" class="sidebar-link">🤝 Multi-Agent</a>
        <a href="/#hri" class="sidebar-link">🧩 Human-Robot</a>
        <a href="/#railway" class="sidebar-link">🚆 Railway AI</a>
        <a href="/#field" class="sidebar-link">🏗️ Field Robotics</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-title">Impact</div>
        <a href="/#impact" class="sidebar-link">🏥 Healthcare</a>
        <a href="/#impact" class="sidebar-link">🏭 Industry</a>
        <a href="/#impact" class="sidebar-link">🌾 Agriculture</a>
        <a href="/#impact" class="sidebar-link">🔬 Science</a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-title">More</div>
        <a href="/#about" class="sidebar-link">👥 About Us</a>
        <a href="mailto:contact@mail.eailab.site" class="sidebar-link">✉️ Contact</a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="main">
      <slot />
    </main>
  </div>

  <footer class="site-footer">
    <span>© 2026 EAI LAB</span>
    <a href="mailto:contact@mail.eailab.site">contact@mail.eailab.site</a>
  </footer>

  <script>
    // Mobile menu
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('mobile-nav');
    if (btn && nav) {
      btn.addEventListener('click', () => {
        const open = nav.classList.toggle('open');
        btn.textContent = open ? '✕' : '☰';
        document.body.style.overflow = open ? 'hidden' : '';
      });
      nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
        nav.classList.remove('open');
        btn.textContent = '☰';
        document.body.style.overflow = '';
      }));
    }

    // Search filter
    const input = document.getElementById('search-input');
    if (input) {
      input.addEventListener('input', (e) => {
        const q = (e.target as HTMLInputElement).value.toLowerCase();
        document.querySelectorAll('.topic-card').forEach((card) => {
          const text = card.textContent?.toLowerCase() || '';
          (card as HTMLElement).style.display = text.includes(q) ? '' : 'none';
        });
      });
    }

    // Active sidebar link on scroll
    const sections = document.querySelectorAll('section[id], h2[id]');
    const sidebarLinks = document.querySelectorAll('.sidebar-link[href^="/#"]');
    const activateLink = () => {
      let current = '';
      sections.forEach((s) => {
        if (window.scrollY >= (s as HTMLElement).offsetTop - 200) current = s.id;
      });
      sidebarLinks.forEach((a) => {
        const href = a.getAttribute('href');
        a.classList.toggle('active', href === '/#' + current);
      });
    };
    window.addEventListener('scroll', activateLink);
    activateLink();
  </script>
</body>
</html>
