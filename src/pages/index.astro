---
import Layout from '../layouts/Layout.astro';
---

<Layout title="EAI LAB | Embodied Intelligence Research Center">

  <!-- HERO — warm, literary feel -->
  <section class="hero" id="top">
    <div class="container">
      <div class="hero-content">
        <div class="hero-eyebrow fade-up">Embodied Intelligence Research Center</div>
        <h1 class="fade-up">Machines that learn<br />by touching the world.</h1>
        <p class="hero-desc fade-up">
          Most AI lives behind a screen. We study what happens when intelligence has a body — when it must deal with gravity, friction, and the unpredictable nature of the real world.
        </p>
        <div class="hero-tags fade-up">
          <span class="htag">Manipulation</span>
          <span class="htag">Locomotion</span>
          <span class="htag">Perception</span>
          <span class="htag">Railway AI</span>
          <span class="htag">Field Robotics</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT — split layout with pillars -->
  <section class="section" id="about">
    <div class="container">
      <div class="about-split">
        <div class="left">
          <h2 class="fade-up">What is Embodied AI?</h2>
          <p class="fade-up">
            Traditional AI processes text and images on servers far from the physical world. <strong>Embodied AI gives intelligence a body.</strong>
          </p>
          <p class="fade-up">
            An embodied agent perceives its surroundings through cameras, touch sensors, and proprioception. It builds internal models of the world, plans actions, and physically interacts with its environment. A robot arm assembling a component, a drone inspecting infrastructure, a household robot tidying a room — these are all embodied AI.
          </p>
          <p class="fade-up">
            The field draws from robotics, computer vision, natural language processing, reinforcement learning, and control theory. Its central question: <strong>how do we build machines that learn to act intelligently through physical experience?</strong>
          </p>
        </div>
        <div class="about-pillars">
          <div class="pillar fade-up">
            <h3>Perception</h3>
            <p>Interpreting raw sensory data — images, depth maps, tactile readings — into meaningful representations of the world.</p>
          </div>
          <div class="pillar pillar-teal fade-up">
            <h3>Reasoning</h3>
            <p>Understanding cause and effect, planning multi-step actions, and predicting how the world responds to interventions.</p>
          </div>
          <div class="pillar pillar-gold fade-up">
            <h3>Interaction</h3>
            <p>Physically engaging with the world — grasping, pushing, assembling — and learning from the consequences of those actions.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- RESEARCH DIRECTIONS -->
  <section class="section section-warm" id="research">
    <div class="container">
      <div class="section-head">
        <h2 class="fade-up">Research Directions</h2>
        <p class="fade-up">The core challenges we study — from how robots grasp objects to how fleets coordinate in the field.</p>
      </div>

      <div class="card-grid">
        <div class="card fade-up">
          <div class="card-num">01</div>
          <h3>Dexterous Manipulation</h3>
          <p>Teaching robots to grasp, reorient, and assemble objects with human-like finesse using tactile sensing and learned motor policies.</p>
        </div>
        <div class="card fade-up">
          <div class="card-num">02</div>
          <h3>Autonomous Navigation</h3>
          <p>Enabling machines to move through complex, unstructured environments using multimodal perception and spatial reasoning.</p>
        </div>
        <div class="card fade-up">
          <div class="card-num">03</div>
          <h3>Language-Guided Interaction</h3>
          <p>Bridging natural language and physical action — grounding words like "pick up the red cup" in perception and motor planning.</p>
        </div>
        <div class="card fade-up">
          <div class="card-num">04</div>
          <h3>Sim-to-Real Transfer</h3>
          <p>Closing the reality gap — training policies in simulation and deploying them on physical systems with minimal fine-tuning.</p>
        </div>
        <div class="card fade-up">
          <div class="card-num">05</div>
          <h3>Multi-Agent Coordination</h3>
          <p>When multiple robots cooperate, they need communication, planning, and emergent coordination strategies.</p>
        </div>
        <div class="card fade-up">
          <div class="card-num">06</div>
          <h3>Human-Robot Collaboration</h3>
          <p>Robots sharing space with people must predict intent, respect safety boundaries, and adapt in real time.</p>
        </div>
        <div class="card fade-up">
          <div class="card-num">07</div>
          <h3>Intelligent Railway Systems</h3>
          <p>Autonomous track inspection, predictive maintenance, obstacle detection, and intelligent dispatching for rail transit.</p>
        </div>
        <div class="card fade-up">
          <div class="card-num">08</div>
          <h3>Field Robotics</h3>
          <p>Deploying agents in environments hazardous to humans — tunnels, offshore platforms, disaster zones, and extreme infrastructure.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE -->
  <section class="section">
    <div class="container">
      <div class="quote-block fade-up">
        <blockquote>
          "The next leap in AI will not come from bigger models alone, but from machines that learn through physical interaction — seeing, touching, and reasoning about the world as humans do."
        </blockquote>
        <cite>EAI LAB</cite>
      </div>
    </div>
  </section>

  <!-- IMPACT — dark section, completely different visual -->
  <section class="section section-dark" id="impact">
    <div class="container">
      <div class="section-head">
        <h2 class="fade-up">Impact on Humanity</h2>
        <p class="fade-up">Embodied AI will reshape how we live, work, and age.</p>
      </div>

      <div class="impact-grid">
        <div class="impact-item fade-up">
          <div class="impact-icon">🏥</div>
          <h3>Healthcare & Eldercare</h3>
          <p>Assistive robots helping an aging population with daily tasks, rehab, and companionship — extending independent living.</p>
        </div>
        <div class="impact-item fade-up">
          <div class="impact-icon">🏭</div>
          <h3>Manufacturing</h3>
          <p>Flexible robots handling small-batch production and unpredictable conditions — making automation accessible beyond large factories.</p>
        </div>
        <div class="impact-item fade-up">
          <div class="impact-icon">🌾</div>
          <h3>Agriculture</h3>
          <p>Autonomous agents monitoring crops, managing invasive species, and operating in hazardous environments at scale.</p>
        </div>
        <div class="impact-item fade-up">
          <div class="impact-icon">🔬</div>
          <h3>Scientific Discovery</h3>
          <p>Robots manipulating lab equipment, running experiments, and exploring extreme environments — accelerating research.</p>
        </div>
        <div class="impact-item fade-up">
          <div class="impact-icon">🏠</div>
          <h3>Daily Life</h3>
          <p>Household robots that cook, clean, and organize — reclaiming hours of domestic labor for creative and social pursuits.</p>
        </div>
        <div class="impact-item fade-up">
          <div class="impact-icon">⚖️</div>
          <h3>Responsibility</h3>
          <p>Raising important questions about safety, employment, and accountability. Building responsibly is as important as building well.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section" id="contact">
    <div class="container" style="max-width:600px;">
      <div class="section-head" style="text-align:center;">
        <h2 class="fade-up">Contact</h2>
        <p class="fade-up" style="margin:0 auto 2rem;">For research inquiries, collaboration proposals, or questions about our work.</p>
        <a href="mailto:contact@mail.eailab.site" class="fade-up" style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.8rem 2rem; background:var(--warm); color:#fff; border-radius:var(--radius); font-weight:600; font-size:0.95rem; transition:all 0.2s;">
          contact@mail.eailab.site →
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand"><strong>EAI</strong> LAB</div>
        <div class="footer-links">
          <a href="#about">About</a>
          <a href="#research">Research</a>
          <a href="#impact">Impact</a>
          <a href="mailto:contact@mail.eailab.site">Contact</a>
        </div>
      </div>
      <div class="footer-bottom">© 2026 EAI LAB. All rights reserved.</div>
    </div>
  </footer>

</Layout>
